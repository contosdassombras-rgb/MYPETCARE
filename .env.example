# Groq API Key: Required for AI symptom guidance (Groq)
# https://console.groq.com/keys
VITE_GROQ_API_KEY="your_groq_api_key_here"

# Supabase: Required for database, auth (Magic Link via Resend)
VITE_SUPABASE_URL="your_supabase_project_url"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Resend: Required for Magic Link email sending (configure via Supabase Auth)
# https://resend.com — configure no painel do Supabase > Auth > SMTP

# Pusher Beams: Required for push notifications
VITE_PUSHER_INSTANCE_ID="your_pusher_beams_instance_id"

# App URL: URL onde o app está hospedado (para callbacks OAuth, links mágicos)
VITE_APP_URL="https://your-app-url.com"

# Hotmart Webhook Secret: Validate webhook signature
HOTMART_WEBHOOK_SECRET="your_hotmart_secret_token"
